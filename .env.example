# PostgreSQL
POSTGRES_DB=library_db
DB_USERNAME=postgres
DB_PASSWORD=change_me_secure_password

# Application database connection (used by Spring Boot)
DB_URL=jdbc:postgresql://postgres:5432/library_db

# JWT (minimum 32 characters)
JWT_SECRET=change_me_to_a_long_random_secret_key_at_least_32_chars
JWT_EXPIRATION_MS=86400000

# === Standard ports (keep in sync with frontend/.env.local) ===
# API:      http://localhost:8080/api
# Frontend: http://localhost:3000

APP_PORT=8080
SPRING_PROFILES_ACTIVE=prod
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend Docker image build args (browser must reach API on host)
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_APP_NAME=Library Management System
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PWA_ENABLED=false
FRONTEND_PORT=3000
