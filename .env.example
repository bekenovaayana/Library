# =============================================================================
# Environment template — copy to `.env` and replace every placeholder.
#
#   cp .env.example .env
#
# Never commit `.env`. This file contains NO production secrets.
# In production use strong, unique values (secret manager / CI secrets).
# =============================================================================

# --- PostgreSQL (Docker service `postgres`) ---
POSTGRES_DB=library_db
DB_USERNAME=postgres
# REQUIRED — min 16 random chars. Example: openssl rand -base64 24
DB_PASSWORD=

# Spring Boot datasource (host `postgres` inside Docker Compose)
DB_URL=jdbc:postgresql://postgres:5432/library_db

# --- JWT (REQUIRED in prod profile) ---
# REQUIRED — min 32 random chars. Example: openssl rand -hex 32
JWT_SECRET=
# Access token TTL (ms). Prod: 3600000 (1h) recommended; dev may use longer locally only.
JWT_EXPIRATION_MS=3600000

# --- Auth: rate limit, refresh, password reset ---
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SEC=60
AUTH_REFRESH_EXPIRATION_DAYS=7
AUTH_PASSWORD_RESET_EXPIRATION_MIN=60
# MUST be false in production (only true for local dev debugging)
AUTH_EXPOSE_RESET_TOKEN=false

# --- Server & Spring ---
# Standard local ports: API :8080, frontend :3000
APP_PORT=8080
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Comma-separated browser origins allowed by CORS (your real frontend URL in prod)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend Docker build (optional; npm run dev uses frontend/.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_APP_NAME=Library Management System
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PWA_ENABLED=false
FRONTEND_PORT=3000

# --- Library lending policy ---
LIBRARY_BORROW_DAYS=14
LIBRARY_MAX_BOOKS_PER_USER=5
LIBRARY_FINE_PER_DAY=1.00
LIBRARY_MAX_FINE=50.00
LIBRARY_REMINDER_DAYS=2
LIBRARY_NOTIFICATIONS_ENABLED=true

# --- Default library manager (created or promoted on app startup) ---
LIBRARY_SEED_ADMIN=true
LIBRARY_ADMIN_USERNAME=admin
LIBRARY_ADMIN_EMAIL=admin@gmail.com
LIBRARY_ADMIN_PASSWORD=Admin12345

# =============================================================================
# Production checklist (set in `.env` or deployment secrets — not here):
#   - DB_PASSWORD: unique, ≥16 chars, not "postgres" / "change_me"
#   - JWT_SECRET: unique, ≥32 chars, not the dev default from application.yml
#   - AUTH_EXPOSE_RESET_TOKEN=false
#   - APP_CORS_ALLOWED_ORIGINS=https://your-frontend-domain
#   - NEXT_PUBLIC_APP_URL / NEXT_PUBLIC_API_URL: real public URLs
# =============================================================================
