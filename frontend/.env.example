# === Standard local development (use these ports only) ===
# Frontend:  http://localhost:3000  (npm run dev)
# Backend:   http://localhost:8080/api  (Docker or mvn spring-boot:run)
#
# Browser calls /api on the same origin; Next.js proxies to the backend (no CORS issues).

NEXT_PUBLIC_API_URL=/api
API_PROXY_TARGET=http://localhost:8080

NEXT_PUBLIC_APP_NAME=Library Management System
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PWA_ENABLED=false

# --- Only for Docker frontend image build (not used with npm run dev) ---
# NEXT_PUBLIC_API_URL=http://localhost:8080/api
