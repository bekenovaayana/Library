# =============================================================================
# Frontend environment template — copy to `.env.local` for local development.
#
#   cp .env.example .env.local
#
# Never commit `.env.local`. No API secrets belong in the Next.js bundle.
# =============================================================================

# --- Local dev (standard ports: frontend :3000, backend :8080) ---
# Browser calls same-origin /api; Next.js proxies to the backend.
NEXT_PUBLIC_API_URL=/api
API_PROXY_TARGET=http://localhost:8080

NEXT_PUBLIC_APP_NAME=Library Management System
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PWA_ENABLED=false

# --- Docker production image build only (uncomment and set real public URLs) ---
# NEXT_PUBLIC_API_URL=https://api.your-domain.example/api
# NEXT_PUBLIC_APP_URL=https://your-domain.example

# =============================================================================
# Notes:
#   - If backend runs on another port, change API_PROXY_TARGET only in `.env.local`.
#   - Add that origin to APP_CORS_ALLOWED_ORIGINS in the root `.env`.
# =============================================================================
